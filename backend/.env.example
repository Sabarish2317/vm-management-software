# Copy this to .env and fill in your values

PORT=3001
PROMETHEUS_URL=http://<tailscale-ip>:9090
PROMETHEUS_TIMEOUT_MS=10000
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:5174
NODE_ENV=development

# MongoDB
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
